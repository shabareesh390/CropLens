rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOfficer() {
      return request.auth != null && exists(/databases/$(database)/documents/officers/$(request.auth.uid));
    }

    match /officers/{userId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /applications/{appId} {
      allow read: if isOfficer() && resource.data.officerId == request.auth.uid;
      allow create: if isOfficer() && request.resource.data.officerId == request.auth.uid;
      allow update: if isOfficer() && resource.data.officerId == request.auth.uid && request.resource.data.officerId == request.auth.uid;
      allow delete: if false;
    }
  }
}
